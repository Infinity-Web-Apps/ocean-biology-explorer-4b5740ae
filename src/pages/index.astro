---
import Base from '../layouts/Base.astro';
---
<Base
  title="OceanLab — Explore Marine Science"
  description="A science-first ocean education platform for kids. Discover marine biology, deep-sea ecosystems, and ocean chemistry through vivid, research-backed content."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Layered ocean gradient background -->
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse at 15% 60%, oklch(0.65 0.19 195 / 0.12), transparent 55%),
      radial-gradient(ellipse at 85% 20%, oklch(0.54 0.17 195 / 0.10), transparent 50%),
      radial-gradient(ellipse at 50% 100%, oklch(0.14 0.025 235 / 0.9), transparent 60%),
      linear-gradient(to bottom, oklch(0.10 0.022 235), oklch(0.13 0.025 235) 50%, oklch(0.10 0.022 235));
    "></div>

    <!-- Floating bubble accents -->
    <div class="absolute top-20 left-[10%] w-64 h-64 rounded-full opacity-5" style="background: radial-gradient(circle, oklch(0.65 0.19 195), transparent);"></div>
    <div class="absolute bottom-32 right-[8%] w-96 h-96 rounded-full opacity-5" style="background: radial-gradient(circle, oklch(0.65 0.19 195), transparent);"></div>
    <div class="absolute top-1/3 right-[25%] w-40 h-40 rounded-full opacity-[0.04]" style="background: radial-gradient(circle, oklch(0.80 0.13 195), transparent);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <!-- Label -->
        <div class="animate-slide-up mb-6 inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium font-display tracking-wide">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
          </svg>
          Science-first ocean education for curious kids
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-surface-950 font-display leading-[1.05] animate-slide-up delay-100">
          Discover every secret<br/>
          <span class="text-brand-500 text-glow">the ocean holds.</span>
        </h1>

        <p class="mt-6 text-xl md:text-2xl text-surface-800/70 max-w-2xl leading-relaxed font-body animate-slide-up delay-200">
          Dive deep into real marine biology — from bioluminescent deep-sea creatures to coral reef ecosystems — built for young scientists aged 8 to 14.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-300">
          <a href="#explore" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 text-surface-50 font-semibold font-display rounded-xl hover:bg-brand-600 transition-colors text-base">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/>
            </svg>
            Start exploring now
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-surface-200/30 text-surface-900 font-semibold font-display rounded-xl hover:border-brand-500/50 hover:text-brand-400 transition-colors text-base">
            See how it works
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
            </svg>
          </a>
        </div>

        <p class="mt-4 text-sm text-surface-800/40 font-display animate-slide-up delay-400">
          Free to explore. No account needed to start.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       STATS BAR
  ════════════════════════════════════════════════════════════ -->
  <section class="py-10 border-y border-surface-200/15 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="animate-fade-in">
          <p class="text-3xl md:text-4xl font-extrabold font-display text-brand-500">71%</p>
          <p class="mt-1 text-sm text-surface-800/50 font-display tracking-wide uppercase">of Earth's surface</p>
        </div>
        <div class="animate-fade-in delay-100">
          <p class="text-3xl md:text-4xl font-extrabold font-display text-brand-500">240,000+</p>
          <p class="mt-1 text-sm text-surface-800/50 font-display tracking-wide uppercase">Known marine species</p>
        </div>
        <div class="animate-fade-in delay-200">
          <p class="text-3xl md:text-4xl font-extrabold font-display text-brand-500">11 km</p>
          <p class="mt-1 text-sm text-surface-800/50 font-display tracking-wide uppercase">Deepest ocean point</p>
        </div>
        <div class="animate-fade-in delay-300">
          <p class="text-3xl md:text-4xl font-extrabold font-display text-brand-500">95%</p>
          <p class="mt-1 text-sm text-surface-800/50 font-display tracking-wide uppercase">Still unexplored</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FEATURES GRID
  ════════════════════════════════════════════════════════════ -->
  <section id="explore" class="py-20 md:py-28 lg:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-slide-up">
        <p class="text-brand-500 font-display font-semibold tracking-widest uppercase text-sm mb-3">What you'll discover</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-950 font-display">Real science, written for young minds</h2>
        <p class="mt-4 text-lg text-surface-800/55 font-body leading-relaxed">
          Every topic is grounded in current marine biology research, then explained in a way that makes a 10-year-old say "whoa."
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="group relative rounded-2xl bg-surface-100 border border-surface-200/20 p-8 hover:border-brand-500/30 transition-colors animate-slide-up delay-100">
          <div class="w-12 h-12 rounded-xl bg-brand-500/15 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 1-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-950 font-display mb-2">Marine Biology</h3>
          <p class="text-surface-800/55 font-body leading-relaxed text-base">
            Anatomy, behavior, and life cycles of sharks, whales, octopuses, and thousands more species — explained through biology, not myth.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="group relative rounded-2xl bg-surface-100 border border-surface-200/20 p-8 hover:border-brand-500/30 transition-colors animate-slide-up delay-200">
          <div class="w-12 h-12 rounded-xl bg-brand-500/15 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-950 font-display mb-2">Bioluminescence</h3>
          <p class="text-surface-800/55 font-body leading-relaxed text-base">
            Learn why anglerfish glow, how firefly squid make light, and the chemistry behind living lanterns in the deep ocean.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="group relative rounded-2xl bg-surface-100 border border-surface-200/20 p-8 hover:border-brand-500/30 transition-colors animate-slide-up delay-300">
          <div class="w-12 h-12 rounded-xl bg-brand-500/15 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-950 font-display mb-2">Ocean Ecosystems</h3>
          <p class="text-surface-800/55 font-body leading-relaxed text-base">
            From coral reef food webs to hydrothermal vent communities — explore how millions of organisms depend on each other to survive.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="group relative rounded-2xl bg-surface-100 border border-surface-200/20 p-8 hover:border-brand-500/30 transition-colors animate-slide-up delay-400">
          <div class="w-12 h-12 rounded-xl bg-brand-500/15 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-950 font-display mb-2">Ocean Chemistry</h3>
          <p class="text-surface-800/55 font-body leading-relaxed text-base">
            Why is the sea salty? How does ocean acidification threaten shells? Real chemistry questions with answers kids actually understand.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       HOW IT WORKS
  ════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28 lg:py-32 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-slide-up">
        <p class="text-brand-500 font-display font-semibold tracking-widest uppercase text-sm mb-3">Simple by design</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-950 font-display">Pick a topic and go deep</h2>
        <p class="mt-4 text-lg text-surface-800/55 font-body leading-relaxed">
          No sign-ups, no paywalls on core content. Just curiosity and science.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 relative">
        <!-- Connecting line (desktop only) -->
        <div class="hidden md:block absolute top-10 left-1/4 right-1/4 h-px bg-gradient-to-r from-transparent via-brand-500/30 to-transparent"></div>

        <!-- Step 1 -->
        <div class="relative text-center animate-slide-up delay-100">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-surface-50 border border-surface-200/20 mb-6">
            <span class="text-3xl font-extrabold font-display text-brand-500">01</span>
          </div>
          <h3 class="text-xl font-bold text-surface-950 font-display mb-3">Choose your zone</h3>
          <p class="text-surface-800/55 font-body leading-relaxed">
            Browse by ocean zone — sunlight, twilight, midnight, abyssal, or hadal — or search for any creature or concept you're curious about.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative text-center animate-slide-up delay-200">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-surface-50 border border-brand-500/25 mb-6">
            <span class="text-3xl font-extrabold font-display text-brand-500">02</span>
          </div>
          <h3 class="text-xl font-bold text-surface-950 font-display mb-3">Read the science</h3>
          <p class="text-surface-800/55 font-body leading-relaxed">
            Every article is written at 5th-grade reading level using real biological terminology — with clear explanations so the vocabulary sticks.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative text-center animate-slide-up delay-300">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-surface-50 border border-surface-200/20 mb-6">
            <span class="text-3xl font-extrabold font-display text-brand-500">03</span>
          </div>
          <h3 class="text-xl font-bold text-surface-950 font-display mb-3">Test your knowledge</h3>
          <p class="text-surface-800/55 font-body leading-relaxed">
            Quick quizzes at the end of every article reinforce key facts and scientific thinking — just enough challenge to make it satisfying.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TOPIC SPOTLIGHT
  ════════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-slide-up">
        <p class="text-brand-500 font-display font-semibold tracking-widest uppercase text-sm mb-3">Explore by zone</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-950 font-display">The ocean has 5 depth zones</h2>
        <p class="mt-4 text-lg text-surface-800/55 font-body leading-relaxed">
          Each one hosts entirely different life — and entirely different science.
        </p>
      </div>

      <div class="space-y-4">
        <!-- Zone 1 -->
        <div class="flex items-center gap-6 rounded-2xl bg-surface-100 border border-surface-200/20 p-6 hover:border-brand-500/30 transition-colors animate-slide-up delay-100">
          <div class="flex-shrink-0 w-16 h-16 rounded-xl flex items-center justify-center font-extrabold font-display text-lg" style="background: oklch(0.65 0.19 195 / 0.15); color: oklch(0.65 0.19 195);">0–200m</div>
          <div class="flex-1">
            <h3 class="text-base font-bold text-surface-950 font-display">Sunlight Zone (Epipelagic)</h3>
            <p class="text-surface-800/55 font-body text-base mt-1">Where 90% of all marine life lives — coral reefs, sea turtles, dolphins, and the base of every ocean food chain.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
          </svg>
        </div>

        <!-- Zone 2 -->
        <div class="flex items-center gap-6 rounded-2xl bg-surface-100 border border-surface-200/20 p-6 hover:border-brand-500/30 transition-colors animate-slide-up delay-200">
          <div class="flex-shrink-0 w-16 h-16 rounded-xl flex items-center justify-center font-extrabold font-display text-lg" style="background: oklch(0.54 0.17 195 / 0.15); color: oklch(0.54 0.17 195);">200m–1km</div>
          <div class="flex-1">
            <h3 class="text-base font-bold text-surface-950 font-display">Twilight Zone (Mesopelagic)</h3>
            <p class="text-surface-800/55 font-body text-base mt-1">Dim, cold, and teeming with hunters — lanternfish, hatchetfish, and the daily vertical migration of billions of animals.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
          </svg>
        </div>

        <!-- Zone 3 -->
        <div class="flex items-center gap-6 rounded-2xl bg-surface-100 border border-surface-200/20 p-6 hover:border-brand-500/30 transition-colors animate-slide-up delay-300">
          <div class="flex-shrink-0 w-16 h-16 rounded-xl flex items-center justify-center font-extrabold font-display text-base" style="background: oklch(0.40 0.12 235 / 0.25); color: oklch(0.72 0.014 235);">1–4km</div>
          <div class="flex-1">
            <h3 class="text-base font-bold text-surface-950 font-display">Midnight Zone (Bathypelagic)</h3>
            <p class="text-surface-800/55 font-body text-base mt-1">Zero sunlight, crushing pressure — yet anglerfish, vampire squid, and sperm whales dive here. Learn how they survive.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
          </svg>
        </div>

        <!-- Zone 4 -->
        <div class="flex items-center gap-6 rounded-2xl bg-surface-100 border border-surface-200/20 p-6 hover:border-brand-500/30 transition-colors animate-slide-up delay-400">
          <div class="flex-shrink-0 w-16 h-16 rounded-xl flex items-center justify-center font-extrabold font-display text-base" style="background: oklch(0.30 0.010 235 / 0.30); color: oklch(0.65 0.014 235);">4–11km</div>
          <div class="flex-1">
            <h3 class="text-base font-bold text-surface-950 font-display">Abyssal &amp; Hadal Zones</h3>
            <p class="text-surface-800/55 font-body text-base mt-1">The ocean trenches — including Challenger Deep at 11 km. Snailfish thrive where submarines are crushed. The frontier of biology.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FINAL CTA
  ════════════════════════════════════════════════════════════ -->
  <section id="cta" class="py-20 md:py-28 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse at 30% 50%, oklch(0.65 0.19 195 / 0.15), transparent 60%),
      radial-gradient(ellipse at 75% 30%, oklch(0.54 0.17 195 / 0.10), transparent 55%),
      linear-gradient(135deg, oklch(0.12 0.025 235), oklch(0.16 0.028 235));
    "></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="animate-slide-up">
        <p class="text-brand-400 font-display font-semibold tracking-widest uppercase text-sm mb-4">The ocean is waiting</p>
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-surface-950 font-display leading-tight">
          95% of the ocean<br/>hasn't been explored yet.<br/>
          <span class="text-brand-500">Your curiosity can change that.</span>
        </h2>
        <p class="mt-6 text-xl text-surface-800/60 font-body leading-relaxed max-w-2xl mx-auto">
          Every marine biologist started as a kid who asked "why?" OceanLab gives young scientists the knowledge to ask better questions.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center animate-slide-up delay-200">
          <a href="#explore" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 text-surface-50 font-semibold font-display rounded-xl hover:bg-brand-600 transition-colors text-lg">
            Begin my ocean journey
          </a>
        </div>
        <p class="mt-4 text-sm text-surface-800/35 font-display">Free to read. Built for kids aged 8–14. Updated monthly with new species.</p>
      </div>
    </div>
  </section>

</Base>
