---
import Base from '../layouts/Base.astro';
---
<Base title='Pelagic Landing Page v1'>
<!-- NAVIGATION -->
  <nav>
    <a href="#" class="nav-logo">PELA<span>GIC</span></a>
    <ul class="nav-links">
      <li><a href="#">Home</a></li>
      <li><a href="#">Animals</a></li>
      <li><a href="#">Ecosystems</a></li>
      <li><a href="#">Science</a></li>
      <li><a href="#">For Teachers</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="particles">
      <div class="particle p1"></div>
      <div class="particle p2"></div>
      <div class="particle p3"></div>
      <div class="particle p4"></div>
      <div class="particle p5"></div>
      <div class="particle p6"></div>
      <div class="particle p7"></div>
      <div class="particle p8"></div>
    </div>
    <div class="hero-content">
      <span class="hero-badge">🌊 Free Ocean Science Education</span>
      <h1>Dive Into the<br /><em>World's Oceans</em></h1>
      <p class="hero-sub">
        Free, science-based learning for curious kids — explore marine life,
        ocean ecosystems, and the biology of the deep. No paywalls. Ever.
      </p>
      <div class="hero-ctas">
        <a href="#topics" class="btn-primary">Start Exploring →</a>
        <a href="#teachers" class="btn-secondary">For Teachers</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <p>✦ Scientifically Accurate &nbsp;&nbsp;✦ Free Forever &nbsp;&nbsp;✦ For Ages 7–14 &nbsp;&nbsp;✦ Teacher-Ready</p>
  </div>

  <!-- TOPIC GRID -->
  <section class="topics" id="topics">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Explore the Ocean</span>
        <h2 class="section-title">What Will You Discover?</h2>
        <p class="section-sub">From apex predators to microscopic plankton — the ocean is full of extraordinary science waiting to be explored.</p>
      </div>
      <div class="topic-grid">
        <div class="topic-card">
          <span class="topic-icon">🦈</span>
          <h3>Sharks &amp; Rays</h3>
          <p>Apex predators that have ruled the ocean for 450 million years.</p>
          <a href="#" class="topic-link">Explore →</a>
        </div>
        <div class="topic-card">
          <span class="topic-icon">🐬</span>
          <h3>Dolphins &amp; Whales</h3>
          <p>The ocean's most intelligent mammals — masters of echolocation and social behavior.</p>
          <a href="#" class="topic-link">Explore →</a>
        </div>
        <div class="topic-card">
          <span class="topic-icon">🐙</span>
          <h3>Octopus &amp; Squid</h3>
          <p>Masters of camouflage with neurons in their arms and three hearts.</p>
          <a href="#" class="topic-link">Explore →</a>
        </div>
        <div class="topic-card">
          <span class="topic-icon">🪸</span>
          <h3>Coral Reefs</h3>
          <p>The rainforests of the sea — home to 25% of all marine species.</p>
          <a href="#" class="topic-link">Explore →</a>
        </div>
        <div class="topic-card">
          <span class="topic-icon">🌊</span>
          <h3>The Deep Sea</h3>
          <p>Explore the hadal zone, where sunlight never reaches and life finds a way.</p>
          <a href="#" class="topic-link">Explore →</a>
        </div>
        <div class="topic-card">
          <span class="topic-icon">🐢</span>
          <h3>Sea Turtles</h3>
          <p>Ancient navigators that have crossed the world's oceans for 100 million years.</p>
          <a href="#" class="topic-link">Explore →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="value-props">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <span class="section-label">Why Pelagic?</span>
        <h2 class="section-title">Science the Way It Should Be Taught</h2>
      </div>
      <div class="props-grid">
        <div class="prop-card">
          <span class="prop-icon">🔬</span>
          <h3>Science-First</h3>
          <p>Every article is written to real biological standards. Real terminology, real research, real understanding — never dumbed down.</p>
        </div>
        <div class="prop-card">
          <span class="prop-icon">🆓</span>
          <h3>Always Free</h3>
          <p>No subscriptions. No paywalls. No ads targeting kids. Pelagic is permanently free because learning should be accessible to everyone.</p>
        </div>
        <div class="prop-card">
          <span class="prop-icon">👩‍🏫</span>
          <h3>Teacher-Ready</h3>
          <p>Curriculum-aligned with NGSS standards. Download lesson plans, assign articles, and inspire the next generation of ocean scientists.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="articles">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Latest From the Deep</span>
        <h2 class="section-title">Start Reading</h2>
        <p class="section-sub">Flagship articles written for curious minds — scientifically rigorous, endlessly fascinating.</p>
      </div>
      <div class="articles-grid">
        <div class="article-card">
          <div class="article-img sharks">🦈</div>
          <div class="article-body">
            <span class="article-tag">Evolution</span>
            <h3>How Sharks Have Survived 450 Million Years</h3>
            <p>Sharks predate dinosaurs by 200 million years. Discover the extraordinary biology that made them nearly indestructible.</p>
            <a href="#" class="article-link">Read More →</a>
          </div>
        </div>
        <div class="article-card">
          <div class="article-img octopus">🐙</div>
          <div class="article-body">
            <span class="article-tag">Intelligence</span>
            <h3>The Hidden Intelligence of Octopuses</h3>
            <p>Three hearts, blue blood, and neurons in every arm. Octopuses are unlike any other creature on Earth.</p>
            <a href="#" class="article-link">Read More →</a>
          </div>
        </div>
        <div class="article-card">
          <div class="article-img coral">🪸</div>
          <div class="article-body">
            <span class="article-tag">Conservation</span>
            <h3>Why Coral Reefs Are Dying (And How We Can Help)</h3>
            <p>Coral reefs support 25% of all marine life. Here's the science behind the crisis — and what we can do about it.</p>
            <a href="#" class="article-link">Read More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEACHERS -->
  <section class="teachers" id="teachers">
    <div class="container">
      <span class="section-label">For Educators</span>
      <h2 class="section-title">Built for the Classroom</h2>
      <p class="section-sub">
        Pelagic provides free, curriculum-aligned marine biology resources for K–8 educators.
        Use our articles in class, download lesson plans, and inspire the next generation of ocean scientists.
        Everything here is NGSS-compatible and completely free.
      </p>
      <a href="#" class="btn-primary">Explore Teacher Resources →</a>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stats-grid">
      <div>
        <span class="stat-number">71%</span>
        <span class="stat-label">of Earth's surface<br />is covered by ocean</span>
      </div>
      <div>
        <span class="stat-number">250,000+</span>
        <span class="stat-label">known marine<br />species discovered</span>
      </div>
      <div>
        <span class="stat-number">95%</span>
        <span class="stat-label">of the ocean<br />remains unexplored</span>
      </div>
      <div>
        <span class="stat-number">1M+</span>
        <span class="stat-label">estimated undiscovered<br />species in the deep</span>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
</Base>
