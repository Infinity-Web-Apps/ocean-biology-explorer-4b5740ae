---
---
<header class="sticky top-0 z-50" style="background: oklch(0.10 0.02 245 / 0.85); backdrop-filter: blur(16px); border-bottom: 1px solid oklch(0.72 0.18 192 / 0.12);">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 font-display font-bold text-xl tracking-tight" style="color: oklch(0.72 0.18 192);">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: oklch(0.72 0.18 192 / 0.12); border: 1px solid oklch(0.72 0.18 192 / 0.25);">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.75 6.75a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h16.5a3 3 0 0 0 3-3V9.75a3 3 0 0 0-3-3H3.75ZM3 10.5a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 10.5Zm.75 2.25a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5h-4.5Z"/>
        </svg>
      </div>
      PELA<span style="color: oklch(0.84 0.15 75);">GIC</span>
    </a>

    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-1">
      <a href="#creatures-section" class="px-3 py-2 text-sm font-medium font-display rounded-lg transition-colors duration-150" style="color: oklch(0.65 0.014 235);" onmouseover="this.style.color='oklch(0.95 0.004 235)';this.style.background='oklch(0.72 0.18 192 / 0.08)'" onmouseout="this.style.color='oklch(0.65 0.014 235)';this.style.background='transparent'">Animals</a>
      <a href="#zones" class="px-3 py-2 text-sm font-medium font-display rounded-lg transition-colors duration-150" style="color: oklch(0.65 0.014 235);" onmouseover="this.style.color='oklch(0.95 0.004 235)';this.style.background='oklch(0.72 0.18 192 / 0.08)'" onmouseout="this.style.color='oklch(0.65 0.014 235)';this.style.background='transparent'">Ocean Zones</a>
      <a href="#science" class="px-3 py-2 text-sm font-medium font-display rounded-lg transition-colors duration-150" style="color: oklch(0.65 0.014 235);" onmouseover="this.style.color='oklch(0.95 0.004 235)';this.style.background='oklch(0.72 0.18 192 / 0.08)'" onmouseout="this.style.color='oklch(0.65 0.014 235)';this.style.background='transparent'">Science Topics</a>
      <a href="#teachers" class="px-3 py-2 text-sm font-medium font-display rounded-lg transition-colors duration-150" style="color: oklch(0.65 0.014 235);" onmouseover="this.style.color='oklch(0.95 0.004 235)';this.style.background='oklch(0.72 0.18 192 / 0.08)'" onmouseout="this.style.color='oklch(0.65 0.014 235)';this.style.background='transparent'">For Teachers</a>
      <a href="/blog" class="px-3 py-2 text-sm font-medium font-display rounded-lg transition-colors duration-150" style="color: oklch(0.65 0.014 235);" onmouseover="this.style.color='oklch(0.95 0.004 235)';this.style.background='oklch(0.72 0.18 192 / 0.08)'" onmouseout="this.style.color='oklch(0.65 0.014 235)';this.style.background='transparent'">Blog</a>
    </div>

    <!-- CTA -->
    <a href="#creatures-section" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold font-display transition-all duration-150" style="background: oklch(0.72 0.18 192); color: oklch(0.08 0.02 245);" onmouseover="this.style.background='oklch(0.65 0.19 192)'" onmouseout="this.style.background='oklch(0.72 0.18 192)'">
      Start Exploring
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    </a>
  </nav>
</header>
